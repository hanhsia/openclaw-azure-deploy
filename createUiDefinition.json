{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy OpenClaw to Azure with optional Azure OpenAI, Feishu, and Microsoft Teams configuration. Microsoft Teams standard mode supports Azure Global only.",
        "location": {
          "label": "Region",
          "toolTip": "Azure region used for both the resource group and the OpenClaw resources created by this template.",
          "resourceTypes": [
            "Microsoft.Compute/virtualMachines",
            "Microsoft.Compute/disks",
            "Microsoft.Network/publicIPAddresses"
          ],
          "visible": true
        }
      }
    },
    "basics": [
      {
        "name": "vmName",
        "type": "Microsoft.Common.TextBox",
        "label": "VM Name",
        "toolTip": "Name of the OpenClaw VM.",
        "defaultValue": "openclaw-vm",
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^[a-zA-Z0-9][a-zA-Z0-9-]{2,63}$",
              "message": "Use 3-64 characters consisting of letters, numbers, or hyphens."
            }
          ]
        }
      },
      {
        "name": "adminUsername",
        "type": "Microsoft.Common.TextBox",
        "label": "Admin Username",
        "toolTip": "Linux administrator username for SSH access.",
        "defaultValue": "azureuser",
        "constraints": {
          "required": true
        }
      },
      {
        "name": "sshPublicKey",
        "type": "Microsoft.Common.TextBox",
        "label": "SSH Public Key",
        "toolTip": "Paste the SSH public key content, not the private key.",
        "multiLine": true,
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^(ssh-(rsa|ed25519)|ecdsa-sha2-nistp(256|384|521))\\s+.+$",
              "message": "Enter a valid SSH public key."
            }
          ]
        }
      },
      {
        "name": "vmSize",
        "type": "Microsoft.Compute.SizeSelector",
        "label": "VM Size",
        "toolTip": "Choose the VM size for the OpenClaw host. The list is filtered by the selected region and Linux support.",
        "recommendedSizes": [
          "Standard_B2as_v2",
          "Standard_D2as_v5",
          "Standard_D4as_v5"
        ],
        "osPlatform": "Linux",
        "count": 1
      },
      {
        "name": "dataDiskSizeGb",
        "type": "Microsoft.Common.TextBox",
        "label": "Data Disk Size (GiB)",
        "toolTip": "Managed data disk size in GiB for /data.",
        "defaultValue": "32",
        "constraints": {
          "required": true,
          "validations": [
            {
              "regex": "^([3-9][2-9]|[1-9][0-9]{2}|10[0-1][0-9]|102[0-4])$",
              "message": "Enter a value from 32 to 1024."
            }
          ]
        }
      },
      {
        "name": "hostname",
        "type": "Microsoft.Common.TextBox",
        "label": "Custom Hostname",
        "toolTip": "Optional. Leave empty to use the Azure-generated public DNS name.",
        "defaultValue": "",
        "constraints": {
          "required": false
        }
      }
    ],
    "steps": [
      {
        "name": "openai",
        "label": "Azure OpenAI (Recommended)",
        "elements": [
          {
            "name": "azureOpenAiEndpoint",
            "type": "Microsoft.Common.TextBox",
            "label": "Endpoint",
            "toolTip": "Fill in all three Azure OpenAI fields together, or leave all three empty.",
            "defaultValue": "",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "azureOpenAiDeployment",
            "type": "Microsoft.Common.TextBox",
            "label": "Deployment Name",
            "toolTip": "Azure OpenAI deployment name used by OpenClaw as the primary model ref.",
            "defaultValue": "",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "azureOpenAiApiKey",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "API Key",
              "confirmPassword": "Confirm API Key"
            },
            "toolTip": "API key for the Azure OpenAI resource.",
            "options": {
              "hideConfirmation": true
            },
            "constraints": {
              "required": false
            }
          }
        ]
      },
      {
        "name": "feishu",
        "label": "Feishu (Optional)",
        "elements": [
          {
            "name": "feishuAppId",
            "type": "Microsoft.Common.TextBox",
            "label": "Feishu App ID",
            "toolTip": "Optional. Fill in both Feishu fields together, or leave both empty.",
            "defaultValue": "",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "feishuAppSecret",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Feishu App Secret",
              "confirmPassword": "Confirm Feishu App Secret"
            },
            "toolTip": "Optional Feishu App Secret.",
            "options": {
              "hideConfirmation": true
            },
            "constraints": {
              "required": false
            }
          }
        ]
      },
      {
        "name": "teams",
        "label": "Microsoft Teams (Optional)",
        "elements": [
          {
            "name": "msteamsAppId",
            "type": "Microsoft.Common.TextBox",
            "label": "Bot App ID",
            "toolTip": "Optional. Fill in both Teams fields together, or leave both empty. Standard mode uses the current Azure tenant automatically. Azure Global only.",
            "defaultValue": "",
            "constraints": {
              "required": false
            }
          },
          {
            "name": "msteamsAppPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Bot App Password",
              "confirmPassword": "Confirm Bot App Password"
            },
            "toolTip": "Optional Microsoft Teams Bot App Password for standard mode.",
            "options": {
              "hideConfirmation": true
            },
            "constraints": {
              "required": false
            }
          }
        ]
      }
    ],
    "outputs": {
      "vmName": "[basics('vmName')]",
      "adminUsername": "[basics('adminUsername')]",
      "sshPublicKey": "[basics('sshPublicKey')]",
      "vmSize": "[basics('vmSize')]",
      "dataDiskSizeGb": "[int(basics('dataDiskSizeGb'))]",
      "location": "[location()]",
      "hostname": "[basics('hostname')]",
      "azureOpenAiEndpoint": "[steps('openai').azureOpenAiEndpoint]",
      "azureOpenAiDeployment": "[steps('openai').azureOpenAiDeployment]",
      "azureOpenAiApiKey": "[steps('openai').azureOpenAiApiKey.password]",
      "feishuAppId": "[steps('feishu').feishuAppId]",
      "feishuAppSecret": "[steps('feishu').feishuAppSecret.password]",
      "msteamsAppId": "[steps('teams').msteamsAppId]",
      "msteamsAppPassword": "[steps('teams').msteamsAppPassword.password]"
    }
  }
}